# --- Host Permissions ---
PUID=1000
PGID=1000

# --- Application Configuration ---
# The port exposed to the host machine's browser
HOST_UI_PORT=8089

# Set your local ISO format timezone here so the internal scheduler executes at the correct time
# Find your exact timezone format here: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Etc/UTC

# Logging level (INFO or DEBUG)
LOG_LEVEL=INFO

# --- Scanning Target ---
# The absolute path on the host machine to be scanned. 
# Windows users: Use forward slashes (/) instead of backslashes (\)
HOST_SCAN_TARGET=/path/to/your/nas/data
